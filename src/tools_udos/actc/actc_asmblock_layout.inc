.ifndef ACTC_ASMBLOCK_LAYOUT_INC
ACTC_ASMBLOCK_LAYOUT_INC = 1

; Pass 4 assembles each inline block into one page in the bank-0 REU slab.
; Pass 9 reads the page and emits ordinary OBJ machine/relocation records.
; Fixed-routine metadata lives at the same offsets in reserved bank $FF.
ACTC_ASMBLOCK_MAX = 15
ACTC_ASMBLOCK_REU_HI_BASE = $00
ACTC_ASMBLOCK_REU_BANK = $FF
; Reserve the top of the overlay scratch window outside linker-allocated BSS.
; Resident ACTC remains below $8000 and pass code starts at $A000.
ACTC_ASMBLOCK_PAGE_BUFFER = ACTC_OVERLAY_WORKSPACE_BASE
ACTC_ASMBLOCK_LABEL_INDEX_BASE = ACTC_ASMBLOCK_PAGE_BUFFER + $0100
ACTC_ASMBLOCK_PASS9_SCRATCH = ACTC_ASMBLOCK_LABEL_INDEX_BASE + $0010
ACTC_ASMBLOCK_REU_PARAMS = ACTC_OVERLAY_REU_PARAMS_ZP

ACTC_ASMBLOCK_MAGIC = $A6
ACTC_ASMBLOCK_VERSION = 3
ACTC_ASMBLOCK_HEADER_MAGIC = 0
ACTC_ASMBLOCK_HEADER_VERSION = 1
ACTC_ASMBLOCK_HEADER_CODE_LEN = 2
ACTC_ASMBLOCK_HEADER_LABEL_COUNT = 3
ACTC_ASMBLOCK_HEADER_RELOC_COUNT = 4
ACTC_ASMBLOCK_HEADER_PROC_INDEX = 5

ACTC_ASMBLOCK_CODE_BASE = $10
ACTC_ASMBLOCK_CODE_CAPACITY = $B0
ACTC_ASMBLOCK_LABEL_BASE = $C0
ACTC_ASMBLOCK_LABEL_MAX = 16
ACTC_ASMBLOCK_RELOC_BASE = $D0
ACTC_ASMBLOCK_RELOC_MAX = 16
ACTC_ASMBLOCK_RELOC_STRIDE = 2
; One signed byte per relocation preserves all existing page capacities while
; covering byte offsets within native Action values and records.
ACTC_ASMBLOCK_RELOC_ADDEND_BASE = $F0
ACTC_ASMBLOCK_RELOC_VAR = $80
; Label indices occupy 0-15, leaving bit 4 available for a module export.
ACTC_ASMBLOCK_RELOC_EXPORT = $10
ACTC_ASMBLOCK_RELOC_KIND_MASK = $60
ACTC_ASMBLOCK_RELOC_TARGET_MASK = $1F
ACTC_ASMBLOCK_RELOC_INDEX_MASK = $0F
ACTC_ASMBLOCK_RELOC_WORD = $00
ACTC_ASMBLOCK_RELOC_LOW = $20
ACTC_ASMBLOCK_RELOC_HIGH = $40

ACTC_ASM_MODE_IMPLIED = 0
ACTC_ASM_MODE_ACCUMULATOR = 1
ACTC_ASM_MODE_IMMEDIATE = 2
ACTC_ASM_MODE_ZP = 3
ACTC_ASM_MODE_ZP_X = 4
ACTC_ASM_MODE_ZP_Y = 5
ACTC_ASM_MODE_ABSOLUTE = 6
ACTC_ASM_MODE_ABSOLUTE_X = 7
ACTC_ASM_MODE_ABSOLUTE_Y = 8
ACTC_ASM_MODE_INDIRECT = 9
ACTC_ASM_MODE_INDEXED_INDIRECT = 10
ACTC_ASM_MODE_INDIRECT_INDEXED = 11
ACTC_ASM_MODE_RELATIVE = 12

.endif
