.ifndef ACTC_OVERLAY_ABI_INC
ACTC_OVERLAY_ABI_INC = 1

; ACTC pass overlays are staged into REU, copied into the execution window,
; then called by the resident compiler driver.
; ABI v5 appends the resident binary32 REAL CONST evaluator callback.
ACTC_OVERLAY_ABI_VERSION = 5

; Pass code uses RAM under BASIC ROM. UDOS owns HIRAM from $C000 upward, so the
; execution window has a hard $BFFF ceiling. Overlay-only mutable scratch lives
; above the resident ACTC image and below this code window.
ACTC_OVERLAY_EXEC_BASE = $A000
ACTC_OVERLAY_EXEC_SIZE = $2000
ACTC_OVERLAY_EXEC_END = ACTC_OVERLAY_EXEC_BASE + ACTC_OVERLAY_EXEC_SIZE
ACTC_OVERLAY_SCRATCH_BASE = $8000
ACTC_OVERLAY_SCRATCH_SIZE = $2000
ACTC_OVERLAY_SCRATCH_END = ACTC_OVERLAY_SCRATCH_BASE + ACTC_OVERLAY_SCRATCH_SIZE
; Keep the top $0200 bytes out of linker-allocated BSS. ASMBLOCK needs one
; transfer page plus label and emitter state that must survive BSS writes.
ACTC_OVERLAY_BSS_SIZE = $1E00
ACTC_OVERLAY_WORKSPACE_BASE = ACTC_OVERLAY_SCRATCH_BASE + ACTC_OVERLAY_BSS_SIZE
C64_MEMCFG = $0001
C64_MEMCFG_BASIC_OFF_MASK = $FE
ACTC_OVERLAY_WORK_ZP = $F9
ACTC_OVERLAY_CONTEXT_ZP = $FB
ACTC_OVERLAY_SCAN_ZP = $FD
; Resident ACTC file/REU parameter scratch; overlays may borrow it while active.
ACTC_OVERLAY_REU_PARAMS_ZP = $E2

; Keep pass overlay storage away from source ($010000+) and current compiler
; table slabs ($00C000-$00EFFF).
